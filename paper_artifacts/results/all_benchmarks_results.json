{
  "name": "LLMForge benchmark suite",
  "description": "Zero-shot benchmark accuracies for the 9 models in the FineWeb-Edu-10BT comparison table",
  "training": {
    "dataset": "FineWeb-Edu sample-10BT",
    "tokens": "13.1B",
    "iterations": 100000,
    "batch_size": 64,
    "block_size": 1024,
    "gradient_accumulation_steps": 2,
    "optimizer": "AdamW (beta1=0.9, beta2=0.99, weight_decay=0.1)",
    "schedule": "cosine, 3e-4 -> 3e-5 over 100K iters with 2K warmup",
    "precision": "bfloat16",
    "init_from": "scratch"
  },
  "evaluation": {
    "harness": "benchmarks/evaluate_custom_models.py + eval_wg_sciq_fixed.py",
    "scoring": "length-normalized log-likelihood (acc_norm); per-choice ctx for SciQ open-book",
    "block_size": 1024,
    "precision": "bfloat16",
    "split": "validation"
  },
  "benchmark_metadata": {
    "arc_easy": {
      "examples": 570,
      "choices": 4,
      "random": 0.25,
      "note": "easy school science"
    },
    "arc_challenge": {
      "examples": 299,
      "choices": 4,
      "random": 0.25,
      "note": "hard school science"
    },
    "boolq": {
      "examples": 3270,
      "choices": 2,
      "random": 0.5,
      "note": "reading comprehension yes/no"
    },
    "hellaswag": {
      "examples": 10042,
      "choices": 4,
      "random": 0.25,
      "note": "sentence completion / commonsense"
    },
    "sciq": {
      "examples": 1000,
      "choices": 4,
      "random": 0.25,
      "note": "science Q&A WITH support passage (open-book, lm-eval-harness compatible)"
    }
  },
  "evaluated_at_utc": "2026-05-06",
  "note": "WinoGrande dropped (~50% across all models, dominated by noise at this training scale)",
