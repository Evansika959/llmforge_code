# =============================================================================
# Python build / runtime caches
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
build/
dist/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# =============================================================================
# Editor / IDE / OS
# =============================================================================
.vscode/
.idea/
*.iml
*.sublime-project
*.sublime-workspace
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# =============================================================================
# Local environments
# =============================================================================
.env
.envrc
*.local
venv/
.venv/
env/
ENV/

# =============================================================================
# AI tooling caches
# =============================================================================
.claude/
.aider*
.cursor/
.copilot-config.json

# =============================================================================
# Generic run-time outputs
# =============================================================================
*.log
*.out
logs/
out/
outputs/
wandb/
mlruns/
tensorboard/

# =============================================================================
# NSGA-II search artifacts
#   run_cosearch.py writes to <cwd>/ckpts/<exp_name>/<gen>.json. Most scripts
#   cd into llmforge/ first, so the live output dir is llmforge/ckpts/. Catch
#   both. The legacy real-train trainer writes payloads to <cwd>/train/.
#
#   Important: llmforge/surrogate/ckpts/ holds the *bundled* release Forge-
#   Former checkpoints (forgeformer.pt etc.) and is NOT ignored.
# =============================================================================
/llmforge/ckpts/
/llmforge/ckpts_paper/
/llmforge/train/
/ckpts/
/train/

# =============================================================================
# Hardware evaluation cache
#   Timeloop writes per-shape mapping outputs under hw_eval/runs/.
#   These are regenerated on-demand and should never be committed.
# =============================================================================
llmforge/hw_eval/runs/
llmforge/hw_eval/runs_*/

# =============================================================================
# Predictor-verification regenerable artifacts
#   * Bundled release checkpoints under llmforge/surrogate/ckpts/ ARE checked
#     in (the trained Forge-Former, ~840 KB).
#   * Multi-seed retrained checkpoints, fitted RF/MLP baselines, per-seed
#     rendered tables, and aggregated tables are all regenerated by
#     example_scripts/surrogate_ablation.bash and should not land in git.
# =============================================================================
llmforge/paper_plot/predictor_verify/ckpts/
llmforge/paper_plot/predictor_verify/hw_gpt_bench/ckpts/
llmforge/paper_plot/predictor_verify/per_seed_tables/
llmforge/paper_plot/predictor_verify/baselines/
llmforge/paper_plot/predictor_verify/table_a.md
llmforge/paper_plot/predictor_verify/table_a.tex
llmforge/paper_plot/predictor_verify/table_a_aggregated.md
llmforge/paper_plot/predictor_verify/table_a_aggregated.tex

# =============================================================================
# Rendered figures
#   Plot scripts write PDFs/PNGs back into the repo. The figures themselves
#   live in the paper repo, not here; everything emitted is regenerable.
# =============================================================================
example_scripts/*.pdf
example_scripts/*.png
example_scripts/figs/
llmforge/paper_plot/figs/
llmforge/paper_plot/predictor_verify/figs/
llmforge/paper_plot/pareto_trends/figs/
llmforge/paper_plot/hw_gpt_bench/figs/

# =============================================================================
# Dataset / blob cache
#   Pretraining datasets (MiniPile, FineWeb-Edu) are not bundled — they are
#   rehydrated from HuggingFace by the prepare scripts. Catch any local copies.
# =============================================================================
*.tar
*.tar.gz
*.zip
*.bin
data/
llmforge_train/data/

# =============================================================================
# LaTeX intermediates (in case anyone builds a paper draft inside the repo)
# =============================================================================
*.aux
*.fls
*.fdb_latexmk
*.synctex.gz
*.toc
*.bbl
*.blg
*.lof
*.lot

# =============================================================================
# Scratch / backup
# =============================================================================
*.bak
*.orig
*.tmp
*.rej
